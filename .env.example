# ── KnowledgeForge Environment Variables ──

# Required
GEMINI_API_KEY=              # Google AI Studio free key
GITHUB_TOKEN=                # GitHub PAT (public repo access, no scope needed)

# Graph backend: "neo4j" or "memory"
GRAPH_BACKEND=memory
NEO4J_URI=                   # neo4j+s://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Pipeline
PIPELINE_SCHEDULE=0 3 * * *  # Cron syntax, default daily 3AM UTC
PIPELINE_TARGETS=openclaw/openclaw,NVIDIA/NemoClaw

# Security
CANARY_SECRET=               # Auto-generated UUID if not set

# Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
